# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server-side only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — get from dashboard.stripe.com (add later)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Your app's public URL (used for Stripe redirects + Supabase OAuth callback)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
